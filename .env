# GENERAL
# app.database_driver; available: mock | mysql | postgre
app.database_driver = mysql # available: mock | mysql | postgre

#app.keyvalue_driver; available: map | redis | mock
app.keyvalue_driver = 

app.listener_port = {your_port_number}
app.log_rotation_at = 00:05
app.catalog_per_page = 10

# MYSQL CONFIGURATION
mysql.username={your_username}
mysql.password={your_password}
mysql.address={your_mysql_host}
mysql.port={your_mysql_port}
mysql.name={your_mysql_database_name}

mysql.maxpoolsize=100
mysql.maxidleconn=100
mysql.maxconnlifetime=3

# RABBIT MQ
rabbit.use = true
rabbit.host = {rabbitmq_host:port}
rabbit.password = {rabbitmq_password}
rabbit.user = ussidev
rabbit.heartbeat_period = 60 # in second
rabbit.reconnect_period = 10  # in second
rabbit.exchange = {rabbit_exchange_name}

# Konfigurasi untuk publisher, buang jika project hanya sebagai consumer
rabbit.exchange_type = fanout

# Konfigurasi untuk consumer, buang jika project hanya digunakan sebagai publisher
# Untuk penambahan waktu percobaan consumer restart saat disconnect dari rabbit.reconnect_period. 
# Periode consumer restart = rabbit.reconnect_period + rabbit.consumer_add_retry_periode, 
# agar memastikan reconnect ke rabbit sukses dan channel telah dibuat, baru dilakukan restart consumer
rabbit.consumer_add_retry_periode = 10 # in second; 
rabbit.queue_name = order-request
rabbit.routing_key = ""


# LOGSTASH CONFIGURATION
logstash.host = ""
logstash.time_location = "Asia/Jakarta"

# RELOADABLE CONFIGURATION
app.log = true


